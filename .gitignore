# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Signing + store credentials. NONE of this may ever be committed — losing the
# release keystore means never being able to update the app on Play again, and
# leaking it lets anyone ship as us. Keep backups outside the repo.
android/key.properties
**/*.jks
**/*.keystore
**/*.p12
**/*.p8
**/*.mobileprovision
**/*.cer
ios/certificates/
play-service-account.json
firebase-service-account.json

# Firebase native config — per-project identifiers, pulled from the console.
# See docs/FIREBASE.md; the build wires itself up when these are present.
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

tools/atlas/*.geojson

# Scratch design research (stock reference images)
tools/atlas_materials/
tools/gpt_atlas/

# Stamp originals — 1024px PNGs at ~1.9MB each, kept out of the repo.
# assets/images/stamps/ ships the WebP versions; these are only here so a
# stamp can be re-encoded at another size without paying to generate it again.
tools/atlas/stamps_raw/

# Generated Play Games import bundles
tools/game_services/out/
